import urllib.request
import tempfile
import cfgrib
import xarray as xr

base_url = "https://nomads.ncep.noaa.gov/pub/data/nccf/com/gfs/prod/gfs.20260224/00/atmos/gfs.t00z.pgrb2.0p25.f000"

with tempfile.NamedTemporaryFile(suffix='.grb2') as tmp:
    print("Downloading...")
    urllib.request.urlretrieve(base_url, tmp.name)
    print("Opening datasets...")
    datasets = cfgrib.open_datasets(tmp.name)
    ds = xr.merge(datasets, compat='override')

# ds is still accessible here, but the temp file is gone
u10 = ds['u10']
v10 = ds['v10']
